# ============================================================
# VALORANT Scrim Analyzer - Environment Variables
# コピーして .env.local にリネームしてください
# ============================================================

# --- Database ---
# Railway: Dashboardから接続文字列をコピー
# Supabase: Settings > Database > Connection string
DATABASE_URL=postgresql://user:password@host:port/dbname

# --- AI ---
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- App ---
NEXT_PUBLIC_DEFAULT_TEAM_ID=your-team-uuid-here

# --- Contact form ---
# お問い合わせメールの送信先アドレス
CONTACT_EMAIL=your@email.com

# --- Optional: Railway Redis (future caching) ---
# REDIS_URL=redis://...

# --- Supabase Auth ---
# Supabase Dashboard > Project Settings > API で確認
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxx
# SUPABASE_SERVICE_ROLE_KEY=xxxx  ← 管理者操作が必要な場合のみ

# --- メール認証コールバックURL ---
# 本番環境のURLを設定（末尾スラッシュなし）
# 開発環境は window.location.origin を自動使用するため不要
# NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
#
# Supabase Dashboard での設定も必要:
#   Authentication > URL Configuration > Redirect URLs に以下を追加:
#     http://localhost:3000/auth/callback   ← 開発
#     https://your-app.vercel.app/auth/callback  ← 本番
